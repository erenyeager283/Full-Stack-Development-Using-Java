('Vikash',    'vikash@example.com', '2004-05-20', 'IT',  '9123456780'),
('Ananya',    'ananya@example.com', '2003-11-02', 'ECE', '9000011122');

-- 3. Retrieve all student records
SELECT student_id, name, email, dob, department, phone
FROM students;

-- 4. Retrieve students from a specific department (example: CSE)
SELECT name, email, dob, phone
FROM students
WHERE department = 'CSE';

-- 5. Check structure of the table (optional)
DESCRIBE students;
